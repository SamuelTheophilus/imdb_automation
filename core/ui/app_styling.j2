<script>
/**
 * Upload-zone click handler — runs CLIENT-SIDE only.
 *
 * NiceGUI Python click handlers lose the browser's "user gesture context"
 * due to the WebSocket round-trip, so programmatic input.click() from Python
 * gets silently blocked. This listener fires synchronously in the same call
 * stack as the user's click, which is the only way browsers allow a
 * file-picker to open without a direct click on the input itself.
 *
 * Uses capture phase so it fires before any child element's own handlers.
 */
(function () {
  function init() {
    document.addEventListener('click', function (e) {
      var zone = e.target.closest('.upload-zone');
      if (!zone) return;
      // Avoid re-triggering when the real file input is what was clicked
      if (e.target.matches('input[type="file"]')) return;
      var inp = zone.querySelector('input[type="file"]');
      if (inp) inp.click();
    }, true); // true = capture phase
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>

