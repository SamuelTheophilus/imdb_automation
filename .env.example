# VLM backend: anthropic | openai | gemini | ollama
VLM_BACKEND=anthropic

# Anthropic (Claude Sonnet 4.6) — recommended
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
VLM_BATCH_SIZE=8

# OpenAI (GPT-5.5) — alternative
OPENAI_API_KEY=sk-...
OPENAI_VL_MODEL=gpt-5.5-2026-04-23

# Ollama (local, optional)
VL_MODEL=qwen2.5vl:32b
OLLAMA_CONCURRENCY=2

# Gemini (optional)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Gmail SMTP for password reset emails
# Generate an App Password at: https://myaccount.google.com/apppasswords
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# NiceGUI session encryption key (any random string)
STORAGE_SECRET=change-me

# Set to YES to skip VLM calls and return a dummy record (useful for UI demos)
IMDB_USE_DUMMY_EXTRACTION=NO

# Set to YES to show the public info page and block all other routes
COMING_SOON_MODE=NO
